#!/bin/bash
# omarkit install
# Usage: install [--all] [mod=CTRL] [left=left] [down=down] [up=up] [right=right]
set -euo pipefail

export OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"

PLUGIN_DIR="$(cd "$(dirname "$0")" && pwd)"
KITTY_CONF="$HOME/.config/kitty/kitty.conf"
OUT_CONF="$HOME/.config/kitty/omarkit.conf"
ENVS_CONF="$HOME/.config/hypr/envs.conf"
HYPR_CONF="$HOME/.config/hypr/hyprland.conf"
HYPR_BINDINGS="$HOME/.config/hypr/omarkit-bindings.conf"

MOD="${OMARKIT_MOD:-SUPER}"
MOD2="${OMARKIT_MOD2:-ALT}"
MOD3="${OMARKIT_MOD3:-CTRL}"
LEFT="${OMARKIT_LEFT:-h}"
DOWN="${OMARKIT_DOWN:-a}"
UP="${OMARKIT_UP:-e}"
RIGHT="${OMARKIT_RIGHT:-i}"

RUN_ALL=false
[[ "${1:-}" == "--all" ]] && RUN_ALL=true

# CLI args override env vars (skip --all flag)
[[ "${1:-}" != "--all" ]] && MOD="${1:-$MOD}"
LEFT="${2:-$LEFT}"
DOWN="${3:-$DOWN}"
UP="${4:-$UP}"
RIGHT="${5:-$RIGHT}"

# Fail if plugin dir is missing
if [[ ! -d "$PLUGIN_DIR" ]]; then
  echo -e "\033[31m✖ plugin dir not found: $PLUGIN_DIR\033[0m"
  exit 1
fi

# Fail if kitty is not installed
if ! command -v kitty &>/dev/null; then
  echo -e "\033[31m✖ kitty is not installed.\033[0m"
  exit 1
fi


step_envs() {
  touch "$ENVS_CONF"
  local tmp
  tmp=$(grep -v '^env = OMARKIT_PATH' "$ENVS_CONF")
  printf '%s\n' "$tmp" > "$ENVS_CONF"
  echo "env = OMARKIT_PATH,$PLUGIN_DIR" >> "$ENVS_CONF"
  echo "  updated $ENVS_CONF"
}

step_render() {
  sed \
    -e "s|{{MOD}}|$MOD|g" \
    -e "s|{{LEFT}}|$LEFT|g" \
    -e "s|{{DOWN}}|$DOWN|g" \
    -e "s|{{UP}}|$UP|g" \
    -e "s|{{RIGHT}}|$RIGHT|g" \
    -e "s|{{PLUGIN_DIR}}|$PLUGIN_DIR|g" \
    "$PLUGIN_DIR/kitty/omarkit.conf.tmpl" > "$OUT_CONF"
  echo "  wrote $OUT_CONF"
}


step_hypr_bindings() {
  cat > "$HYPR_BINDINGS" << HYPR
# omarkit bindings — generated by omarkit install, do not edit manually

# MOD + dir => Focus window
bindd = $MOD, $LEFT,  Focus window left,  exec, omarchy-movefocus-hypr left
bindd = $MOD, $DOWN,  Focus window down,  exec, omarchy-movefocus-hypr down
bindd = $MOD, $UP,    Focus window up,    exec, omarchy-movefocus-hypr up
bindd = $MOD, $RIGHT, Focus window right, exec, omarchy-movefocus-hypr right

# MOD + arrow => Focus window (arrow aliases)
bindd = $MOD, left,  Focus window left,  exec, omarchy-movefocus-hypr left
bindd = $MOD, down,  Focus window down,  exec, omarchy-movefocus-hypr down
bindd = $MOD, up,    Focus window up,    exec, omarchy-movefocus-hypr up
bindd = $MOD, right, Focus window right, exec, omarchy-movefocus-hypr right

# MOD + MOD2 + dir => Move window
bindd = $MOD $MOD2, $LEFT,  Move window left,  movewindow, l
bindd = $MOD $MOD2, $DOWN,  Move window down,  movewindow, d
bindd = $MOD $MOD2, $UP,    Move window up,    movewindow, u
bindd = $MOD $MOD2, $RIGHT, Move window right, movewindow, r

# MOD + CTRL + ALT + dir => Resize window (routed via daemon: nvim splits → kitty splits → hyprland)
bindd = $MOD CTRL ALT, $LEFT,  Resize window left,  exec, omarchy-movefocus-hypr --resize left
bindd = $MOD CTRL ALT, $DOWN,  Resize window down,  exec, omarchy-movefocus-hypr --resize down
bindd = $MOD CTRL ALT, $UP,    Resize window up,    exec, omarchy-movefocus-hypr --resize up
bindd = $MOD CTRL ALT, $RIGHT, Resize window right, exec, omarchy-movefocus-hypr --resize right
HYPR
  echo "  wrote $HYPR_BINDINGS"
}

step_wire_hypr() {
  if ! grep -q "omarkit-bindings.conf" "$HYPR_CONF" 2>/dev/null; then
    echo "source = $HOME/.config/hypr/omarkit-bindings.conf" >> "$HYPR_CONF"
    echo "  added omarkit-bindings.conf source to $HYPR_CONF"
  else
    echo "  omarkit-bindings.conf already sourced in $HYPR_CONF"
  fi
  if ! grep -q "omarchy-nav-daemon" "$HYPR_CONF" 2>/dev/null; then
    echo "exec-once = omarchy-nav-daemon" >> "$HYPR_CONF"
    echo "  added exec-once omarchy-nav-daemon to $HYPR_CONF"
  else
    echo "  omarchy-nav-daemon already in $HYPR_CONF"
  fi
}

step_wire_kitty() {
  if ! grep -q "omarkit.conf" "$KITTY_CONF" 2>/dev/null; then
    echo "include $OUT_CONF" >> "$KITTY_CONF"
    echo "  added include to $KITTY_CONF"
  else
    echo "  omarkit.conf already included in $KITTY_CONF"
  fi
}

step_cleanup_kitty() {
  # Remove bindings now owned by omarkit.conf
  sed -i '/kitten smart_close/d' "$KITTY_CONF"
  sed -i '/kitten relative_resize/d' "$KITTY_CONF"
  sed -i '/var:IS_NVIM.*alt+ctrl/d' "$KITTY_CONF"
  sed -i '/var:IS_NVIM.*semicolon/d' "$KITTY_CONF"
  echo "  removed duplicate bindings from $KITTY_CONF"
}

step_bins() {
  mkdir -p "$HOME/.local/bin"
  cp -f "$PLUGIN_DIR/bin/omarchy-kitty"          "$HOME/.local/bin/omarchy-kitty"
  cp -f "$PLUGIN_DIR/bin/omarchy-movefocus-hypr" "$HOME/.local/bin/omarchy-movefocus-hypr"
  cp -f "$PLUGIN_DIR/bin/omarchy-nav-daemon"     "$HOME/.local/bin/omarchy-nav-daemon"
  chmod +x "$HOME/.local/bin/omarchy-kitty" "$HOME/.local/bin/omarchy-movefocus-hypr" "$HOME/.local/bin/omarchy-nav-daemon"
  echo "  copied bins to ~/.local/bin"
}

step_reload_kitty() {
  pkill -SIGUSR1 -x kitty && echo "  reloaded config in all kitty windows"
}

step_waybar() {
  omarchy-refresh-waybar 2>/dev/null || true
  echo "  refreshed waybar"
}

run_render()  { step_envs; step_render; step_hypr_bindings; }
run_wire()    { step_bins; step_wire_hypr; step_wire_kitty; step_cleanup_kitty; }
run_reload()  { step_reload_kitty; step_waybar; }

groups=(
  "Render configs (envs, kitty conf, hypr bindings):run_render"
  "Wire dotfiles (bins, hyprland.conf, kitty.conf):run_wire"
  "Reload (kitty, waybar):run_reload"
)

labels=()
for g in "${groups[@]}"; do labels+=("${g%%:*}"); done

if [[ "$RUN_ALL" == "true" ]] || ! [[ -t 0 ]]; then
  selected=$(printf '%s\n' "${labels[@]}")
else
  selected=$(IFS=, ; printf '%s\n' "${labels[@]}" | gum choose --no-limit --header "omarkit install" --selected "${labels[*]}")
fi

[[ -z "$selected" ]] && echo "Nothing selected." && exit 0

for g in "${groups[@]}"; do
  label="${g%%:*}"
  fn="${g#*:}"
  if echo "$selected" | grep -qF "$label"; then
    echo -e "\n\033[32m▶ $label\033[0m"
    $fn
  fi
done

echo -e "\n\033[32mDone.\033[0m"
