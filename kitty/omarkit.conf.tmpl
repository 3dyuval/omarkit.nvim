# omarkit.conf — include at the END of kitty.conf

# ── Close ──────────────────────────────────────────────────────────────────
map ctrl+w         kitten {{PLUGIN_DIR}}/kitty/smart_close.py
map ctrl+shift+w   kitten {{PLUGIN_DIR}}/kitty/smart_close.py --all

# ── Passthrough: unset kitty ctrl+* bindings per focused app ───────────────
# ctrl+w (smart_close) intentionally kept for all apps.
# Resize (alt+ctrl+dir) is handled by Hyprland → daemon — unset here so kitty
# doesn't intercept when daemon sends-key ctrl+alt+* to nvim.
map --when-focus-on var:IS_NVIM alt+ctrl+{{LEFT}}
map --when-focus-on var:IS_NVIM alt+ctrl+{{DOWN}}
map --when-focus-on var:IS_NVIM alt+ctrl+{{UP}}
map --when-focus-on var:IS_NVIM alt+ctrl+{{RIGHT}}
map --when-focus-on var:IS_NVIM ctrl+semicolon
map --when-focus-on var:IS_NVIM ctrl+h
map --when-focus-on var:IS_NVIM ctrl+a
map --when-focus-on var:IS_NVIM ctrl+e
map --when-focus-on var:IS_NVIM ctrl+i
map --when-focus-on var:IS_NVIM alt+left
map --when-focus-on var:IS_NVIM alt+down
map --when-focus-on var:IS_NVIM alt+up
map --when-focus-on var:IS_NVIM alt+right
map --when-focus-on var:IS_NVIM ctrl+y
map --when-focus-on var:IS_NVIM ctrl+k
map --when-focus-on var:IS_NVIM ctrl+s
map --when-focus-on var:IS_NVIM ctrl+l
map --when-focus-on var:IS_NVIM ctrl+d
map --when-focus-on var:IS_NVIM ctrl+t
map --when-focus-on var:IS_NVIM ctrl+enter
