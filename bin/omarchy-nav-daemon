#!/usr/bin/env python3
"""omarchy-nav-daemon — persistent nav state machine.

Listens on $XDG_RUNTIME_DIR/omarchy-nav.sock.
Protocol: one line per message: "<direction> <pid>"
  direction: left | right | up | down
  pid:       kitty OS window PID
"""
import json
import os
import signal
import socket
import subprocess
import sys

SOCK_PATH = os.path.join(
    os.environ.get('XDG_RUNTIME_DIR', f'/run/user/{os.getuid()}'),
    'omarchy-nav.sock'
)

HYPR_DIR  = {'left': 'l', 'right': 'r', 'up': 'u', 'down': 'd'}
KITTY_DIR = {'left': 'left', 'right': 'right', 'up': 'top', 'down': 'bottom'}
KITTY_KEY = {'left': 'ctrl+h', 'right': 'ctrl+i', 'up': 'ctrl+e', 'down': 'ctrl+a'}


def kitty_run(sock_addr, *args, text=False):
    r = subprocess.run(
        ['kitten', '@', '--to', sock_addr, *args],
        capture_output=True, text=text
    )
    return r


def kitty(sock_addr, *args):
    return kitty_run(sock_addr, *args).returncode == 0


def kitty_ls(sock_addr):
    r = kitty_run(sock_addr, 'ls', text=True)
    if r.returncode != 0:
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def hyprctl(direction):
    subprocess.run(
        ['hyprctl', 'dispatch', 'movefocus', HYPR_DIR[direction]],
        capture_output=True
    )


def dispatch(direction, pid):
    sock_addr = f'unix:@mykitty-{pid}'

    state = kitty_ls(sock_addr)
    if state is None:
        hyprctl(direction)
        return

    os_win = next((w for w in state if w.get('is_focused')), None)
    if not os_win:
        hyprctl(direction)
        return

    tab = next((t for t in os_win['tabs'] if t.get('is_active')), None)
    if not tab:
        hyprctl(direction)
        return

    win = next((w for w in tab['windows'] if w.get('is_active') and w.get('is_focused')), None)

    # IS_NVIM: pass key through to nvim
    if win and win.get('user_vars', {}).get('IS_NVIM'):
        kitty(sock_addr, 'send-key', KITTY_KEY[direction])
        return

    # Neighboring kitty split
    if kitty(sock_addr, 'focus-window', '--match', f'neighbor:{KITTY_DIR[direction]}'):
        return

    # Adjacent tab (horizontal only)
    if direction in ('left', 'right'):
        tabs = os_win['tabs']
        active_idx = next((i for i, t in enumerate(tabs) if t.get('is_active')), None)
        if active_idx is not None:
            target_idx = active_idx - 1 if direction == 'left' else active_idx + 1
            if 0 <= target_idx < len(tabs):
                kitty(sock_addr, 'focus-tab', '--match', f"id:{tabs[target_idx]['id']}")
                return

    hyprctl(direction)


def serve():
    try:
        os.unlink(SOCK_PATH)
    except OSError:
        pass

    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(SOCK_PATH)
    srv.listen(8)
    os.chmod(SOCK_PATH, 0o600)

    def shutdown(*_):
        try:
            os.unlink(SOCK_PATH)
        except OSError:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    while True:
        conn, _ = srv.accept()
        try:
            data = conn.recv(64).decode().strip()
            parts = data.split()
            if len(parts) == 2 and parts[0] in HYPR_DIR:
                dispatch(parts[0], parts[1])   # from hyprland binding (has kitty pid)
            elif len(parts) == 1 and parts[0] in HYPR_DIR:
                hyprctl(parts[0])              # from nvim edge (no kitty context needed)
        except Exception:
            pass
        finally:
            conn.close()


if __name__ == '__main__':
    serve()
